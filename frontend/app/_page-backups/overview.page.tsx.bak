"use client";

import { useEffect, useMemo, useState } from "react";
import DashboardNav from "@/components/dashboard-nav";
import ControlBar from "@/components/control-bar";
import { useAppState } from "@/lib/app-state";
import { getWeekData, type ResolvedDashboardData } from "@/lib/data-resolver";

export default function Page() {
  const { selectedWeek } = useAppState();
  const [search, setSearch] = useState("");
  const [data, setData] = useState<ResolvedDashboardData | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    let cancelled = false;

    async function load() {
      try {
        setLoading(true);
        setError(null);
        const nextData = await getWeekData(selectedWeek);
        if (!cancelled) setData(nextData);
      } catch (err) {
        if (!cancelled) {
          setError(err instanceof Error ? err.message : "Failed to load dashboard");
          setData(null);
        }
      } finally {
        if (!cancelled) setLoading(false);
      }
    }

    load();
    return () => {
      cancelled = true;
    };
  }, [selectedWeek]);

  const filteredOperators = useMemo(() => {
    if (!data) return [];
    return data.operators.filter(
      (o) =>
        o.name.toLowerCase().includes(search.toLowerCase()) ||
        o.area.toLowerCase().includes(search.toLowerCase())
    );
  }, [data, search]);

  const weeklySummary = data?.weeklySummary;
  const areas = data?.areas || [];

  return (
    <main className="min-h-screen bg-slate-100 text-slate-900 p-3 md:p-4">
      <div className="mx-auto max-w-7xl space-y-4">
        <DashboardNav />
        <ControlBar />

        <section className="rounded-2xl bg-white border shadow-sm p-4">
          <div className="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 className="text-xl font-bold">Overview</h2>
              <p className="mt-1 text-xs text-slate-600">
                Current warehouse activity snapshot
              </p>
            </div>

            <div className="text-xs text-slate-500">
              {new Date(selectedWeek + "T00:00:00").toLocaleDateString()}
            </div>
          </div>
        </section>

        {loading && (
          <section className="rounded-2xl bg-white border shadow-sm p-4 text-sm text-slate-600">
            Loading dashboard data...
          </section>
        )}

        {error && (
          <section className="rounded-2xl bg-white border shadow-sm p-4 text-sm text-red-600">
            {error}
          </section>
        )}

        {!loading && !error && weeklySummary && (
          <>
            <section className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-3">
              <div className="rounded-2xl bg-white border shadow-sm p-4">
                <div className="text-xs text-slate-500">Total Handled</div>
                <div className="mt-2 grid grid-cols-2 gap-3">
                  <div>
                    <div className="text-xs text-slate-500">Plates</div>
                    <div className="text-2xl font-semibold">{weeklySummary.totalPlates.toLocaleString()}</div>
                  </div>
                  <div>
                    <div className="text-xs text-slate-500">Pieces</div>
                    <div className="text-2xl font-semibold">{weeklySummary.totalPieces.toLocaleString()}</div>
                  </div>
                </div>
              </div>

              <div className="rounded-2xl bg-white border shadow-sm p-4">
                <div className="text-xs text-slate-500">Receiving</div>
                <div className="mt-2 grid grid-cols-2 gap-3">
                  <div>
                    <div className="text-xs text-slate-500">Plates</div>
                    <div className="text-2xl font-semibold">{weeklySummary.receivingPlates.toLocaleString()}</div>
                  </div>
                  <div>
                    <div className="text-xs text-slate-500">Pieces</div>
                    <div className="text-2xl font-semibold">{weeklySummary.receivingPieces.toLocaleString()}</div>
                  </div>
                </div>
              </div>

              <div className="rounded-2xl bg-white border shadow-sm p-4">
                <div className="text-xs text-slate-500">Average</div>
                <div className="mt-2">
                  <div className="text-xs text-slate-500">Pieces per Plate</div>
                  <div className="text-2xl font-semibold">{weeklySummary.avgPiecesPerPlate.toFixed(1)}</div>
                </div>
              </div>

              <div className="rounded-2xl bg-white border shadow-sm p-4">
                <div className="text-xs text-slate-500">Date</div>
                <div className="mt-2">
                  <div className="text-lg font-semibold">{weeklySummary.weekLabel}</div>
                  <div className="text-xs text-slate-500">Current display period</div>
                </div>
              </div>
            </section>

            <section className="grid grid-cols-1 xl:grid-cols-3 gap-3">
              <div className="xl:col-span-2 rounded-2xl bg-white border shadow-sm p-4">
                <h2 className="text-lg font-semibold">Top Operators</h2>
                <input
                  value={search}
                  onChange={(e) => setSearch(e.target.value)}
                  placeholder="Search operator or area"
                  className="mt-3 w-full rounded-xl border px-3 py-2"
                />

                <div className="mt-3 space-y-2">
                  {filteredOperators.slice(0, 5).map((o, idx) => (
                    <div key={o.userid} className="rounded-xl border p-3 flex items-center justify-between gap-4">
                      <div>
                        <div className="font-medium text-sm">
                          #{idx + 1} {o.name}
                        </div>
                        <div className="text-xs text-slate-500">
                          {o.area}
                          {o.assignedRole ? ` • ${o.assignedRole}` : ""}
                        </div>
                      </div>
                      <div className="text-right grid grid-cols-2 gap-4">
                        <div>
                          <div className="text-xs text-slate-500">Plates</div>
                          <div className="font-semibold">{o.totalPlates.toLocaleString()}</div>
                        </div>
                        <div>
                          <div className="text-xs text-slate-500">Pieces</div>
                          <div className="font-semibold">{o.totalPieces.toLocaleString()}</div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div className="rounded-2xl bg-white border shadow-sm p-4">
                <h2 className="text-lg font-semibold">Assigned Area Snapshot</h2>
                <div className="mt-3 space-y-2">
                  {areas.map((a) => (
                    <div key={a.area} className="rounded-xl border p-3">
                      <div className="font-medium text-sm">{a.area}</div>
                      <div className="mt-2 grid grid-cols-2 gap-3">
                        <div>
                          <div className="text-xs text-slate-500">Plates</div>
                          <div className="font-semibold">{a.plates.toLocaleString()}</div>
                        </div>
                        <div>
                          <div className="text-xs text-slate-500">Pieces</div>
                          <div className="font-semibold">{a.pieces.toLocaleString()}</div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </section>
          </>
        )}
      </div>
    </main>
  );
}
